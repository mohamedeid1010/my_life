rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Matches any document in the 'users' collection or its subcollections
    match /users/{userId}/{document=**} {
      // Allow read and write only if the user is authenticated and is the owner of the data
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Gym profile specific rule (subset of above, but explicit for clarity)
    match /users/{userId}/gym_profile/main {
       allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
