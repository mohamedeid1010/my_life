# ═══════════════════════════════════════════════
#  Horizon — Environment Variables Template
#
#  ✅ This file IS safe to commit to git.
#     It shows what variables are required
#     without containing any real values.
#
#  HOW TO USE:
#  1. Copy this file to .env.development (for local dev)
#  2. Copy this file to .env.production  (for builds)
#  3. Fill in the real values from Firebase Console
#     Project Settings > Your Apps > SDK setup
# ═══════════════════════════════════════════════

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
